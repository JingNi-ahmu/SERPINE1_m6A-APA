library(tidyverse)
library(ggplot2)
library(reshape2)
Tumor<-read.delim("E:\\APA\\data\\MeRIP-seq\\data\\annotated_Peaks\\Tumor_peaks_annotated.txt",header = TRUE, 
                    quote = "",  
                    sep = "\t",
                    check.names = FALSE) 
Normal<- read.delim("E:\\APA\\data\\MeRIP-seq\\data\\annotated_Peaks\\Normal_peaks_annotated.txt",header = TRUE, 
                    quote = "",     
                    sep = "\t",     
                    check.names = FALSE) 
df<-list(Tumor=as.character(Tumor$Annotation),Normal=as.character(Normal$Annotation))
type_comb <- map_dfr(df, function(x) {
  if (length(x) == 0) return(NULL)
  tmp <- sapply(strsplit(x, split = '\\('), '[', 1)
  clean_type <- trimws(tmp)
  as.data.frame(table(clean_type))
}, .id = "Group") 
type_comb$Sample <- c('Tumor', 'Normal')

final <-type_comb
colnames(final) <- c("Sample", "Feature", "Count")
final <- final %>%
  group_by(Sample) %>%
  mutate(Percent = Count / sum(Count)) %>%
  ungroup()

my_colors <- c(
  "#E64B35CC", 
  "#4DBBD5CC", 
  "#00A087CC", 
  "#3C5488CC", 
  "#F39B7FCC", 
  "#8491B4CC", 
  "#91D1C2CC", 
  "#DC0000CC", 
  "#7E6148CC"  
)

ggplot(final, aes(x = "", y = Percent, fill = Feature)) +
  geom_col(width = 1, color = "white") + 
  coord_polar(theta = "y") + 
  facet_wrap(~Sample) + 
  theme_void() + 
  theme(
    legend.position = 'right',
    strip.text.x = element_text(size = 14, face = "bold"),
    plot.title = element_text(hjust = 0.5, size = 16)
  ) +

  scale_fill_manual(values = my_colors, name = 'Genomic Features') +
  ggtitle("Distribution of Genomic Regions")




