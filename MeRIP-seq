res_df <- fread("m6A_peaks_p0.05.csv")

fc_cutoff <- 0 # log2FC > 1 或 < -1
fdr_cutoff <- 0.05

res_df$group <- "Not Significant"
res_df$group[res_df$log2FoldChange > fc_cutoff & res_df$fdr < fdr_cutoff] <- "Hyper"
res_df$group[res_df$log2FoldChange < -fc_cutoff & res_df$fdr < fdr_cutoff] <- "Hypo"

ggplot(res_df, aes(x = log2FoldChange, y = -log10(fdr), color = group)) +
  geom_point(alpha = 0.6, size = 1.5) +
  scale_color_manual(values = c("Hyper" = "#E41A1C", "Hypo" = "#377EB8", "Not Significant" = "grey")) +
  geom_vline(xintercept = c(-fc_cutoff, fc_cutoff), linetype = "dashed", color = "black") +
  geom_hline(yintercept = -log10(fdr_cutoff), linetype = "dashed", color = "black") +
  theme_bw() +
  labs(title = "Volcano Plot of Differential m6A Peaks",
       x = "log2 Fold Change (Tumor / Normal)",
       y = "-log10 FDR") +
  theme(plot.title = element_text(hjust = 0.5))



